# ============================================================
# MISOCIO PRINTER - Configuracion
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS MYSQL (MiSocio)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=misocio
DB_USERNAME=root
DB_PASSWORD=

# ------------------------------------------------------------
# IMPRESORA
# PRINTER_TYPE: windows | network | file
# ------------------------------------------------------------
PRINTER_NAME=POS80
PRINTER_TYPE=windows
PAPER_WIDTH=37

# Solo para tipo "network":
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# ------------------------------------------------------------
# INFORMACION DE LA EMPRESA
# ------------------------------------------------------------
COMPANY_NAME=DISTRIBUIDORA
COMPANY_LOGO=¤ FADI ¤
FOOTER_MESSAGE=__GRACIAS POR SU COMPRA__
CONTACT_INFO=CEL: 73010688

# ------------------------------------------------------------
# CONFIGURACION DE RECIBOS
# ------------------------------------------------------------
SHOW_LOGO=true
SHOW_QR=true
AUTO_CUT=true
SOUND_ALERT=true

# Nombre del archivo de logo (ruta relativa a uploads/logo/)
LOGO_IMAGE=
